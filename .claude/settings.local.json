{
  "permissions": {
    "allow": [
      "Bash(git checkout:*)",
      "Bash(git add:*)",
      "mcp__playwright__browser_take_screenshot"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "TodoWrite|Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude\\play_sound.py\"",
            "timeout": 15
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python \".claude\\play_sound.py\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
